l[h] = w[!w %in% l[-h]][1]
if(is.na(l[h])){
delta[,h] = 0
}else{
delta[1:l[h],h] = 0
delta[l[h]:p, h] =  phi[l[h]:p,h]
}
}
}
# return the last phi and delta
return(list("Phi" = phi, "Delta"= delta))
}
