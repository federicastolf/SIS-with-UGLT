colnames(my_data)
commodities <- c(
"Copper", "Platinum", "OilPrice", "Silver", "Gold", "Soybean", "Cocoa", "Aluminum",
"Coal", "Corn", "Lambs", "Nickel", "Onions", "Oranges", "Potatoes", "Rice", "Wool",
"Cotton"
)
# Define categories
commodity_groups <- list(
Metals = c("Copper", "Platinum", "Silver", "Gold", "Aluminum", "Nickel"),
Energy = c("OilPrice", "Coal"),
Agri_Food = c("Soybean", "Cocoa", "Corn", "Onions", "Oranges", "Potatoes", "Rice"),
Agri_Livestock_Fiber = c("Lambs", "Wool", "Cotton")
)
# Function to map
map_to_group <- function(x, groups) {
for (g in names(groups)) {
if (x %in% groups[[g]]) return(g)
}
return(NA)
}
# Apply mapping
commodity_category <- sapply(commodities, map_to_group, groups = commodity_groups)
# Combine into data frame
result <- data.frame(Commodity = commodities, Category = commodity_category)
View(result)
