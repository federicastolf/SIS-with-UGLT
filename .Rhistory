library(pheatmap)
library(gridExtra)
library(ggplotify)
library(pheatmap)
library(patchwork)
rm(list=ls())
simCov = function(m, H, pilogit, NiterGibbs){
## Allocate structures
Phi = array(NA, dim = c(NiterGibbs, m, H))
Delta = array(NA, dim = c(NiterGibbs, m, H))
covMl = vector("list", NiterGibbs)
#---# Initialization #----#
phi = matrix(rbinom(m*H, 1, 0.2), m, H)
delta = phi
Phi[1,,] = phi
l=rep(NA, H) # pivots
l[1] = which(phi[,1]>0)[1]
for(h in 2:H){
w = which(phi[,h]>0) # conto gli 1 nella colonna h di delta
l[h] = w[!w %in% l[-h]][1] # prendo il primo
if(is.na(l[h])){
delta[,h] = 0 # metto tutta la colonna a zero
}else{
delta[1:l[h],h] = 0 # prima del pivots tutti zero
delta[l[h]:m, h] =  phi[l[h]:m,h] # dal pivots in poi seguono phi[,l]
}
}
delta[,colSums(delta)==1] = rep(0, m) # remove spurious
active = which(colSums(delta)>0)
beta = delta[,active] # subset active columns
covM = beta %*% t(beta)
# dicotomize the entries of covM: sparse VS not sparse
covMl[[1]] = matrix(as.numeric(covM>0), nrow(covM), ncol(covM))
for(t in 2:NiterGibbs){
for(h in 1:H){
Lh = sort(l[-h])
p_h = pilogit[,h]
k = 0
# definisco prob di phi_h condizionatamente agli altri pivot
for(pl in Lh){
k = k+1
if (pl-k>0){
scale = 1-prod(1-pilogit[1:pl,h][-Lh[1:k]])
p_h[pl] = min(p_h[pl]/scale, 1)
}
else{
p_h[pl] = 1
}
}
phi[,h] = rbinom(m,1,p_h) # generate phi
w = which(phi[,h]>0)
l[h] = w[!w %in% l[-h]][1]
if(is.na(l[h])){
delta[,h] = 0
}else{
delta[1:l[h],h] = 0
delta[l[h]:m, h] =  phi[l[h]:m,h]
}
}
delta[,colSums(delta)==1] = rep(0, m) # remove spurious
Phi[t,,] = phi
Delta[t,,] = delta
#------# loading matrix #-------#
active = which(colSums(delta)>0) # subset only active columns
beta = delta[,active]
covM = beta %*% t(beta)
# dicotomize the entries of covM: sparse VS not sparse
covMl[[t]] = matrix(as.numeric(covM>0), nrow(covM), ncol(covM))
}
return(list("Phi" = Phi, "Delta"= Delta,"covMl"=covMl))
}
m = 30 # number of rows of beta
H = 15 # number of column of beta
Nsim = 500 # number of simulations
NiterGibbs = 3000
burnin = 1500
set.seed(435)
cp = 0.35
xf = as.factor(c(rep(1,10), rep(2,10), rep(3,10)))
Xm = model.matrix(~xf) # X matrix
theta = matrix(rnorm(3*H, sd=5), 3,H) # theta coefficient
pilogit = cp*plogis(Xm %*% theta) # prob of being sparse
sim1 = simCov(m, H, pilogit, NiterGibbs)
meanCov1 = apply(simplify2array(sim1$covMl[burnin:NiterGibbs]), 1:2, mean)
p1 = pheatmap(meanCov1, treeheight_row = 0, treeheight_col = 0, cluster_rows = F,
cluster_cols = F, border_color ="NA", legend=F,
color = colorRampPalette(c("white", "blue"))(60),
breaks = seq(0, 1, length.out = 60))
p1
